[run]
source = .
omit =
    */migrations/*
    manage.py
    */wsgi.py
    */asgi.py
    */settings.py
    */localsettings*.py
    venv/*
    env/*
    htmlcov/*
    */tests.py

[report]
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    if settings.DEBUG